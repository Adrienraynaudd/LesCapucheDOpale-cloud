DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=guild-db;user=admin;password=yourpassword;encrypt=true"

AZURE_KEYVAULT_URI="https://your-keyvault-name.vault.azure.net/"

AZURE_STORAGE_ACCOUNT_NAME="yourstorageaccount"
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=yourkey;EndpointSuffix=core.windows.net"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"

OAUTH_GITHUB_CLIENT_ID="your_github_oauth_client_id"
OAUTH_GITHUB_CLIENT_SECRET="your_github_oauth_client_secret"

# Optionnel: ces valeurs peuvent etre deduites automatiquement depuis le host public.
# GITHUB_CALLBACK_URL="https://your-public-api-domain/api/auth/github/callback"
# FRONTEND_OAUTH_SUCCESS_URL="https://your-frontend-domain/auth/callback"

LOG_FUNCTION_URL="https://your-function-app.azurewebsites.net/api/log-receiver"

PORT=3000
NODE_ENV=development
