# Configuration PostgreSQL
POSTGRES_DB=guild_db
POSTGRES_USER=guild_user
POSTGRES_PASSWORD=your_secure_password_here

# Configuration JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_SECRET_ADMIN=your_admin_jwt_secret_key_here

# Configuration GitHub OAuth
OAUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost/api/auth/github/callback
FRONTEND_OAUTH_SUCCESS_URL=http://localhost/auth/callback
